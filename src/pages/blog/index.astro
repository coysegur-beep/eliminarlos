---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const categories = [...new Set(posts.map((p) => p.data.category))];
---

<BaseLayout
  title="Blog — Privacidad digital y reputación online"
  description="Guías, casos prácticos y consejos sobre derecho al olvido, gestión de reputación online y privacidad digital."
>
  <TopBar />
  <Header />

  <section class="bg-ink text-white" style="padding: 110px 0 80px;">
    <div class="container-wide">
      <div class="eyebrow">Blog</div>
      <h1 class="font-serif font-normal text-white max-w-[620px]" style="font-size: clamp(38px, 5vw, 62px); line-height: 1.1;">
        Privacidad, reputación<br/><span class="italic text-brand-accent">y derechos digitales.</span>
      </h1>
    </div>
  </section>

  <section class="bg-surface" style="padding: 80px 0 110px;">
    <div class="container-wide">
      <!-- Categorías -->
      <div class="flex flex-wrap gap-2.5 mb-10">
        <span class="bg-brand text-white px-4 py-1.5 rounded-full text-[12.5px] font-semibold">Todos</span>
        {categories.map((cat) => (
          <span class="bg-white border border-ink/[0.1] text-ink-muted px-4 py-1.5 rounded-full text-[12.5px] font-medium hover:border-brand cursor-pointer transition-colors">{cat}</span>
        ))}
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group card card-hover block">
            <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-accent mb-3">{post.data.category}</div>
            <h2 class="font-serif text-[20px] text-ink mb-3 leading-[1.25] group-hover:text-brand transition-colors">{post.data.title}</h2>
            <p class="text-ink-muted text-[14px] leading-[1.65] mb-5">{post.data.description}</p>
            <div class="flex items-center justify-between text-[12.5px] text-ink-light">
              <span>{post.data.author}</span>
              <span>{post.data.publishDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
