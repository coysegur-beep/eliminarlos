---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---
<BaseLayout title="Página no encontrada" noindex={true}>
  <Header />
  <section class="bg-ink text-white min-h-[60vh] flex items-center">
    <div class="container-wide text-center">
      <div class="font-serif text-[120px] font-medium leading-none mb-4" style="color: rgba(168,255,62,0.15);">404</div>
      <h1 class="font-serif text-[36px] text-white mb-4">Página no encontrada</h1>
      <p class="text-[16px] mb-8" style="color:rgba(255,255,255,0.55);">El contenido que buscas no existe o ha sido movido.</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/" class="btn btn-primary">Ir al inicio</a>
        <a href="/servicios" class="btn btn-ghost">Ver servicios</a>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
