---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { SITE, SERVICIOS } from '@/lib/config';

const stats = [
  { number: '+500', label: 'Casos resueltos' },
  { number: '98%', label: 'Tasa de éxito' },
  { number: '100%', label: 'Métodos legales' },
  { number: '24h', label: 'Primera respuesta' },
];

const pasos = [
  {
    n: '01',
    title: 'Analizamos tu caso',
    text: 'Revisamos qué información aparece, de dónde viene y qué vía legal es más efectiva. Gratis y sin compromiso.',
  },
  {
    n: '02',
    title: 'Diseñamos la estrategia',
    text: 'Derecho al olvido, solicitud directa al webmaster, desindexación técnica o combinación. Cada caso es único.',
  },
  {
    n: '03',
    title: 'Ejecutamos y monitorizamos',
    text: 'Gestionamos todo el proceso y vigilamos que el contenido no reaparezca. Te informamos en cada paso.',
  },
];

const faqs = [
  {
    q: '¿Cuánto tarda Google en eliminar una URL?',
    a: 'Depende de la vía. Las solicitudes de datos personales suelen resolverse en días. Casos más complejos pueden llevar semanas. Te damos un plazo realista desde el primer análisis.',
  },
  {
    q: '¿Es siempre posible eliminar contenido de Google?',
    a: 'No siempre, y somos honestos al respecto. Si el contenido es veraz y de interés público, Google no lo retira. En esos casos aplicamos estrategias de desplazamiento para que deje de ser visible.',
  },
  {
    q: '¿Qué es el derecho al olvido?',
    a: 'Es el derecho reconocido por el RGPD que te permite solicitar a Google que retire URLs con información personal irrelevante o desactualizada. Aplica a ciudadanos de la Unión Europea.',
  },
  {
    q: '¿Qué pasa si el contenido reaparece?',
    a: 'Incluimos monitorización continua. Si algo reaparece, lo detectamos y actuamos sin coste adicional.',
  },
];
---

<BaseLayout
  title="Elimina tu información de Google e internet"
  description="Eliminamos URLs, noticias y datos personales de Google con métodos 100% legales. Derecho al olvido, RGPD, gestión de reputación online. Consulta gratis."
  schemaType="home"
>
  <TopBar />
  <Header />

  <!-- HERO -->
  <section class="relative bg-ink text-white overflow-hidden" style="padding: 130px 0 110px;">
    <!-- textura de puntos -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.15]" style="background-image: radial-gradient(circle, #A8FF3E 1px, transparent 1px); background-size: 32px 32px;"></div>
    <!-- gradiente encima de los puntos -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 70% 50%, rgba(26,122,74,0.25) 0%, transparent 55%), radial-gradient(ellipse at 5% 100%, rgba(168,255,62,0.06) 0%, transparent 40%), linear-gradient(to right, #0A0E14 40%, transparent 100%);"></div>

    <div class="container-wide relative z-10">
      <div class="max-w-[800px]">
        <div class="inline-flex items-center gap-2 bg-brand-accent/10 border border-brand-accent/25 text-brand-accent px-4 py-2 rounded-full text-[12px] font-semibold uppercase tracking-[0.1em] mb-8">
          <span class="w-1.5 h-1.5 bg-brand-accent rounded-full animate-pulse-soft"></span>
          Consulta gratuita · Resultado garantizado
        </div>

        <h1 class="font-serif font-normal leading-[1.05] tracking-[-0.025em] mb-7" style="font-size: clamp(42px, 6vw, 80px);">
          Eliminamos tu<br/>
          <span class="italic" style="color: #4ADE80;">pasado digital.</span><br/>
          <span style="color: rgba(255,255,255,0.55);">Protegemos tu futuro.</span>
        </h1>

        <p class="text-[18px] leading-[1.65] mb-10 max-w-[580px]" style="color: rgba(255,255,255,0.7);">
          Borramos URLs, noticias y datos personales de Google e internet con métodos 100% legales. Derecho al olvido, gestión de reputación y privacidad digital.
        </p>

        <div class="flex gap-4 flex-wrap items-center">
          <a href="/contacto" class="btn btn-primary">
            Consulta gratis ahora
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#como-funciona" class="btn btn-ghost">
            Cómo funciona
          </a>
        </div>

        <p class="text-[12.5px] mt-5" style="color: rgba(255,255,255,0.35);">
          Sin letra pequeña · Confidencial · Respuesta en menos de 24 horas
        </p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="container-wide">
    <div class="grid grid-cols-2 md:grid-cols-4 -mt-14 relative z-20 rounded-xl overflow-hidden" style="box-shadow: 0 25px 60px rgba(10,14,20,0.12);">
      {stats.map((s, i) => (
        <div class:list={["bg-white py-8 px-6 text-center border-b border-ink/[0.06]", { "border-r border-ink/[0.06]": i < 3 }]}>
          <div class="font-serif text-[44px] font-medium text-brand leading-none mb-1.5 tracking-[-0.02em]">{s.number}</div>
          <div class="text-[12px] text-ink-muted uppercase tracking-[0.08em] font-medium">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- SERVICIOS -->
  <section class="bg-surface" style="padding: 110px 0;">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-14">
        <div>
          <div class="eyebrow">Servicios</div>
          <h2 class="font-serif font-normal text-ink" style="font-size: clamp(32px, 4vw, 52px); line-height: 1.1;">
            Lo que podemos<br/><span class="italic text-brand">hacer por ti.</span>
          </h2>
        </div>
        <a href="/servicios" class="btn btn-outline flex-shrink-0">Ver todos los servicios</a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {SERVICIOS.map((s, i) => (
          <a href={`/servicios/${s.slug}`} class="group card card-hover block relative overflow-hidden">
            <div class="absolute top-0 left-0 h-[3px] w-0 bg-brand-accent transition-all duration-500 group-hover:w-full"></div>
            <div class="text-[12px] font-semibold text-brand-accent/70 tracking-[0.1em] uppercase mb-4 font-sans">— {String(i+1).padStart(2,'0')}</div>
            <h3 class="font-serif font-medium text-[22px] text-ink mb-3 leading-[1.2]">{s.nombre}</h3>
            <p class="text-ink-muted text-[14.5px] leading-[1.7] mb-5">{s.descripcionCorta}</p>
            <span class="text-brand text-[13px] font-semibold inline-flex items-center gap-2 transition-all group-hover:gap-3">
              Saber más
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section id="como-funciona" class="bg-white" style="padding: 110px 0;">
    <div class="container-wide">
      <div class="text-center mb-16">
        <div class="eyebrow justify-center" style="justify-content: center;">Proceso</div>
        <h2 class="font-serif font-normal text-ink mx-auto" style="font-size: clamp(32px, 4vw, 52px); line-height: 1.1; max-width: 600px;">
          Tres pasos para <span class="italic text-brand">recuperar tu privacidad.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-[960px] mx-auto">
        {pasos.map((p) => (
          <div class="relative">
            <div class="text-[64px] font-serif font-medium leading-none mb-5" style="color: rgba(13,110,78,0.1);">{p.n}</div>
            <div class="absolute top-4 left-0 w-8 h-px bg-brand-accent"></div>
            <h3 class="font-serif text-[22px] text-ink mb-3">{p.title}</h3>
            <p class="text-ink-muted text-[15px] leading-[1.7]">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ ELEGIRNOS -->
  <section class="bg-ink text-white relative overflow-hidden" style="padding: 110px 0;">
    <div class="absolute inset-0 pointer-events-none opacity-[0.07]" style="background-image: radial-gradient(circle, #A8FF3E 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 90% 20%, rgba(26,122,74,0.2) 0%, transparent 50%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <div>
          <div class="eyebrow">Por qué elegirnos</div>
          <h2 class="font-serif font-normal text-white mb-6" style="font-size: clamp(32px, 4vw, 52px); line-height: 1.1;">
            No prometemos<br/><span class="italic text-brand-accent">lo imposible.</span><br/>
            <span style="color: rgba(255,255,255,0.5);">Prometemos resultados.</span>
          </h2>
          <p class="text-[16px] leading-[1.75] mb-10" style="color: rgba(255,255,255,0.65);">
            Equipo multidisciplinar de abogados, técnicos SEO y especialistas en privacidad digital. Analizamos cada caso individualmente y trazamos la ruta más efectiva y legal.
          </p>
          <a href="/contacto" class="btn btn-primary">Analiza tu caso gratis</a>
        </div>

        <div class="grid grid-cols-1 gap-5">
          {[
            { title: 'Métodos 100% legales', text: 'RGPD, políticas de Google, comunicación con webmasters. Sin atajos que puedan perjudicarte.' },
            { title: 'Confidencialidad total', text: 'Tu caso no se comparte, no se indexa, no se menciona. Discreción absoluta garantizada.' },
            { title: 'Sin resultados, sin pago', text: 'Trabajamos con garantía de resultado. Si no logramos el objetivo, no cobras por lo no resuelto.' },
            { title: 'Vigilancia continua', text: 'Monitorizamos que el contenido eliminado no reaparezca. Si vuelve, lo volvemos a eliminar.' },
          ].map((item) => (
            <div class="border border-white/[0.08] rounded-xl p-6 hover:border-brand-accent/30 transition-colors">
              <div class="flex items-start gap-4">
                <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <div>
                  <h4 class="font-sans font-semibold text-[15px] text-white mb-1">{item.title}</h4>
                  <p class="text-[14px] leading-[1.65]" style="color: rgba(255,255,255,0.55);">{item.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-surface" style="padding: 110px 0;">
    <div class="container-tight">
      <div class="text-center mb-14">
        <div class="eyebrow justify-center" style="justify-content: center;">Preguntas frecuentes</div>
        <h2 class="font-serif font-normal text-ink mx-auto" style="font-size: clamp(32px, 4vw, 52px); line-height: 1.1;">
          Dudas <span class="italic text-brand">habituales.</span>
        </h2>
      </div>

      <div class="space-y-4 max-w-[760px] mx-auto">
        {faqs.map((faq, i) => (
          <details class="group bg-white border border-ink/[0.07] rounded-xl overflow-hidden">
            <summary class="flex justify-between items-center px-7 py-5 cursor-pointer font-semibold text-[15.5px] text-ink list-none select-none">
              {faq.q}
              <svg class="w-5 h-5 text-ink-muted flex-shrink-0 ml-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-7 pb-6 text-ink-muted text-[15px] leading-[1.7]">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-ink text-white relative overflow-hidden" style="padding: 100px 0;">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 100%, rgba(168,255,62,0.08) 0%, transparent 60%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <a href="/casos-de-exito" class="group border border-white/[0.08] rounded-xl p-7 hover:border-brand-accent/40 transition-colors">
          <div class="text-brand-accent text-[11px] font-semibold uppercase tracking-[0.12em] mb-3">Casos de éxito</div>
          <h3 class="font-serif text-[20px] text-white mb-2">+500 casos resueltos</h3>
          <p class="text-[13.5px] leading-[1.65]" style="color:rgba(255,255,255,0.5);">Resultados reales de personas y empresas que recuperaron su reputación.</p>
          <span class="text-brand-accent text-[13px] font-semibold inline-flex items-center gap-1.5 mt-4 group-hover:gap-2.5 transition-all">Ver casos <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/faq" class="group border border-white/[0.08] rounded-xl p-7 hover:border-brand-accent/40 transition-colors">
          <div class="text-brand-accent text-[11px] font-semibold uppercase tracking-[0.12em] mb-3">FAQ</div>
          <h3 class="font-serif text-[20px] text-white mb-2">Preguntas frecuentes</h3>
          <p class="text-[13.5px] leading-[1.65]" style="color:rgba(255,255,255,0.5);">Todo lo que necesitas saber antes de empezar, sin tecnicismos.</p>
          <span class="text-brand-accent text-[13px] font-semibold inline-flex items-center gap-1.5 mt-4 group-hover:gap-2.5 transition-all">Ver preguntas <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/blog" class="group border border-white/[0.08] rounded-xl p-7 hover:border-brand-accent/40 transition-colors">
          <div class="text-brand-accent text-[11px] font-semibold uppercase tracking-[0.12em] mb-3">Blog</div>
          <h3 class="font-serif text-[20px] text-white mb-2">Guías y recursos</h3>
          <p class="text-[13.5px] leading-[1.65]" style="color:rgba(255,255,255,0.5);">Artículos sobre derecho al olvido, reputación y privacidad digital.</p>
          <span class="text-brand-accent text-[13px] font-semibold inline-flex items-center gap-1.5 mt-4 group-hover:gap-2.5 transition-all">Ver blog <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
      </div>

      <div class="text-center">
        <h2 class="font-serif font-normal text-white mx-auto mb-5" style="font-size: clamp(32px, 4.5vw, 58px); line-height: 1.1; max-width: 700px;">
          ¿Listo para recuperar el control de <span class="italic text-brand-accent">lo que dicen de ti?</span>
        </h2>
        <p class="text-[17px] max-w-[500px] mx-auto mb-10 leading-[1.65]" style="color: rgba(255,255,255,0.65);">
          Cuéntanos tu caso. Analizamos sin coste y sin compromiso.
        </p>
        <a href="/contacto" class="btn btn-primary text-[16px] px-9 py-4.5">
          Empezar ahora — es gratis
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
